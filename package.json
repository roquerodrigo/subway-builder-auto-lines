{
  "name": "subway-builder-auto-lines",
  "version": "1.0.1",
  "description": "Subway Builder mod that extends a line along its corridor or creates a new line from unserved stations, with demand-based trains.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "install-mod": "npm run build && node scripts/install-mod.mjs",
    "debug": "node scripts/debug.mjs",
    "inspect": "node scripts/cdp-eval.mjs",
    "play": "npm run install-mod && npm run debug",
    "package": "npm run build && node scripts/package-release.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Rodrigo Roque",
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.37.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
